{
  "name": "trace2e",
  "version": "0.1.0",
  "private": true,
  "description": "Record user interactions in Chrome and generate Playwright E2E tests via Claude Code.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "daemon:start": "pnpm --filter @trace2e/daemon start",
    "daemon:dev": "pnpm --filter @trace2e/daemon dev",
    "ext:dev": "pnpm --filter @trace2e/extension dev",
    "ext:build": "pnpm --filter @trace2e/extension build",
    "dist": "node scripts/build-dist.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "typescript": "^5.5.4"
  }
}
